<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.ClaimTypesMapper">

    <select id="selectAll" resultType="com.example.entity.ClaimTypes">
        select * from claim_types
        <where>
            <if test="id != null">and ID = #{id}</if>
            <if test="claimsType != null and claimsType != ''">and Claims_type like concat('%', #{claimsType}, '%')</if>
        </where>
        order by ID desc
    </select>

</mapper>
